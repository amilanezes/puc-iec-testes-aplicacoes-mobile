{
  "files.associations": {
    "flows/**/*.yaml": "yaml",
    "flows/**/*.yml": "yaml"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.autoIndent": "advanced"
  },
  "yaml.format.singleQuote": false,
  "yaml.validate": true,
  "files.exclude": {
    "**/.maestro": true
  }
}
